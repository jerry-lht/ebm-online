{
  "type": "object",
  "properties": {
    "study_id": { "type": "string" },
    "domains": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "domain": { "type": "string" },
          "judgement": { "type": "string", "enum": ["low", "high", "unclear", "unable_to_determine"] },
          "rationale": { "type": "string" },
          "evidence": { "type": "string" }
        },
        "required": ["domain", "judgement", "rationale", "evidence"],
        "additionalProperties": false
      }
    },
    "overall": { "type": "string", "enum": ["low", "high", "unclear", "unable_to_determine"] },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "required": ["study_id", "domains", "overall", "warnings"],
  "additionalProperties": false
}
