#!/usr/bin/env python3
import argparse
import json
import re
import sys
from collections import Counter
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from meta_extract.io_utils import ensure_dir, iter_jsonl, write_json, write_jsonl
from meta_extract.normalize import canonical_numeric_string

NUM_RE = re.compile(r"-?\d+(?:\.\d+)?")


def _observed_numeric_values(study: dict) -> set[str]:
    full_content = (study or {}).get("full_content") or {}
    text = json.dumps(full_content, ensure_ascii=True)
    return {
        normalized
        for match in NUM_RE.finditer(text)
        for normalized in [canonical_numeric_string(match.group(0))]
        if normalized is not None
    }


def _gold_direct_values(instance: dict) -> list[str]:
    values = []
    for row in instance.get("gold_extraction_rows") or []:
        for field in row.get("direct_extraction_fields") or []:
            normalized = canonical_numeric_string(field.get("value"))
            if normalized is not None:
                values.append(normalized)
    return values


def _label_instance(instance: dict) -> dict:
    observed_values = _observed_numeric_values(instance.get("study") or {})
    gold_values = _gold_direct_values(instance)
    missing_values = [value for value in gold_values if value not in observed_values]
    if not gold_values:
        coverage_label = "no_gold_numeric_values"
    elif not missing_values:
        coverage_label = "all_gold_numeric_values_present"
    elif len(missing_values) == len(gold_values):
        coverage_label = "no_gold_numeric_values_present"
    else:
        coverage_label = "partial_gold_numeric_values_present"
    annotated = dict(instance)
    annotated["source_coverage"] = {
        "coverage_label": coverage_label,
        "gold_numeric_value_count": len(gold_values),
        "missing_numeric_value_count": len(missing_values),
        "missing_numeric_values": missing_values,
        "all_gold_numeric_values": gold_values,
    }
    return annotated


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--instances-path", required=True)
    parser.add_argument("--output-dir", required=True)
    parser.add_argument("--split")
    parser.add_argument("--data-type")
    args = parser.parse_args(argv)

    rows = list(iter_jsonl(args.instances_path) or [])
    if args.split:
        rows = [row for row in rows if row.get("split") == args.split]
    if args.data_type:
        rows = [row for row in rows if (row.get("setting_context") or {}).get("data_type") == args.data_type]

    annotated_rows = [_label_instance(row) for row in rows]
    out_dir = ensure_dir(args.output_dir)
    write_jsonl(out_dir / "oracle_source_coverage_annotated.jsonl", annotated_rows)

    by_label = Counter(row["source_coverage"]["coverage_label"] for row in annotated_rows)
    present_rows = [row for row in annotated_rows if row["source_coverage"]["coverage_label"] == "all_gold_numeric_values_present"]
    partial_rows = [row for row in annotated_rows if row["source_coverage"]["coverage_label"] == "partial_gold_numeric_values_present"]
    absent_rows = [row for row in annotated_rows if row["source_coverage"]["coverage_label"] == "no_gold_numeric_values_present"]

    write_jsonl(out_dir / "oracle_source_coverage_all_present.jsonl", present_rows)
    write_jsonl(out_dir / "oracle_source_coverage_partial_present.jsonl", partial_rows)
    write_jsonl(out_dir / "oracle_source_coverage_none_present.jsonl", absent_rows)
    write_json(
        out_dir / "oracle_source_coverage_summary.json",
        {
            "instances_path": str(args.instances_path),
            "split": args.split,
            "data_type": args.data_type,
            "instances": len(annotated_rows),
            "coverage_counts": dict(sorted(by_label.items())),
        },
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
